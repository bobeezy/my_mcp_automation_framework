{
  "name": "my_mcp_automation_framework",
  "version": "1.0.0",
  "description": "AI-assisted test automation framework using **Playwright + JavaScript** and a **Playwright MCP server** workflow to help generate test cases from Jira tickets.",
  "scripts": {
    "pw:install": "PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers npx playwright install --force chromium",
    "test": "PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers playwright test",
    "test:verify": "npm run lint && npm test",
    "test:verify:full": "npm run lint && npm run pw:install && npm test",
    "pretest:web": "npm run pw:install",
    "test:web": "PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers playwright test tests/web",
    "test:api": "PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers playwright test tests/api",
    "test:headed": "PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers playwright test --headed",
    "mcp:playwright": "npx -y @playwright/mcp@latest --browser chrome --output-dir .playwright-mcp --save-session",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "report:playwright": "playwright show-report",
    "report:allure:generate": "allure generate ./allure-results --clean -o ./allure-report",
    "report:allure:open": "allure open ./allure-report",
    "report:allure": "npm run report:allure:generate && npm run report:allure:open"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "allure-commandline": "^2.37.0",
    "allure-playwright": "^3.5.0",
    "eslint": "^9.39.4",
    "eslint-plugin-playwright": "^2.9.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7"
  },
  "dependencies": {
    "dotenv": "^17.3.1"
  }
}
